---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Platform — GetKnown"
  description="GetKnown is an AI-powered reputation engine designed for the Expert Economy. We provide frameworks, visibility tools, and PR infrastructure that transform quiet professionals into industry icons."
>
  <!-- Hero -->
  <section class="bg-[#0F172A] py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="text-[#F97316] text-sm font-semibold font-mono uppercase tracking-widest">The Platform</span>
        <h1 class="mt-4 text-4xl md:text-6xl font-bold text-white leading-tight tracking-tight">Your complete<br />visibility engine.</h1>
        <p class="mt-6 text-xl text-slate-300 leading-relaxed">GetKnown is an AI-powered reputation engine designed for the Expert Economy. We provide the frameworks, visibility tools, and PR infrastructure that transform quiet professionals into industry icons.</p>
        <a href="/audit" class="mt-8 inline-flex items-center gap-2 bg-[#F97316] text-white font-bold px-8 py-4 rounded-full hover:bg-orange-600 transition-colors shadow-lg text-lg">
          Start Your Audit
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9H14M14 9L10 5M14 9L10 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Three Pillars -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#F97316] text-sm font-semibold font-mono uppercase tracking-widest">Core Features</span>
        <h2 class="mt-3 text-4xl md:text-5xl font-bold text-[#0F172A] tracking-tight">Three pillars of authority.</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Personal Brand Foundation -->
        <div class="rounded-xl border border-slate-200 overflow-hidden">
          <div class="bg-[#0F172A] p-8">
            <div class="w-12 h-12 rounded-xl bg-[#F97316]/20 flex items-center justify-center text-[#F97316] mb-4">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
            </div>
            <h3 class="text-xl font-bold text-white">Personal Brand Foundation</h3>
          </div>
          <div class="p-8 space-y-4">
            <p class="text-slate-600">Build the bedrock of your authority with our proven positioning framework.</p>
            <ul class="space-y-3">
              {['AI-powered brand audit & gap analysis', 'Category of One positioning workshop', 'LinkedIn profile optimization score', 'Bio & messaging architecture', 'Authority keyword strategy'].map(item => (
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <svg class="w-4 h-4 text-[#F97316] mt-0.5 flex-shrink-0" viewBox="0 0 16 16" fill="currentColor"><path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Content Visibility -->
        <div class="rounded-xl border border-slate-200 overflow-hidden ring-2 ring-[#F97316]">
          <div class="bg-[#F97316] p-8">
            <div class="flex justify-between items-start">
              <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center text-white mb-4">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <span class="bg-white text-[#F97316] text-xs font-bold px-3 py-1 rounded-full">Most Popular</span>
            </div>
            <h3 class="text-xl font-bold text-white">Content Visibility Engine</h3>
          </div>
          <div class="p-8 space-y-4">
            <p class="text-slate-600">Automate a multi-channel presence that projects your expertise 24/7.</p>
            <ul class="space-y-3">
              {['AI content calendar & topic generator', 'LinkedIn post & article templates', 'Newsletter system (Authority Weekly)', 'Podcast guesting pitch templates', 'Content repurposing workflows', 'Authority SEO optimization'].map(item => (
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <svg class="w-4 h-4 text-[#F97316] mt-0.5 flex-shrink-0" viewBox="0 0 16 16" fill="currentColor"><path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- PR & Scale -->
        <div class="rounded-xl border border-slate-200 overflow-hidden">
          <div class="bg-[#0F172A] p-8">
            <div class="w-12 h-12 rounded-xl bg-[#F97316]/20 flex items-center justify-center text-[#F97316] mb-4">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <h3 class="text-xl font-bold text-white">PR & Authority Scaling</h3>
          </div>
          <div class="p-8 space-y-4">
            <p class="text-slate-600">Bridge into tier-1 media, speaking stages, and high-value networks.</p>
            <ul class="space-y-3">
              {['Tier-1 PR media matching', 'Speaker bureau introduction', 'Podcast host matching algorithm', 'Press kit creation & distribution', 'Analyst & journalist relationship building'].map(item => (
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <svg class="w-4 h-4 text-[#F97316] mt-0.5 flex-shrink-0" viewBox="0 0 16 16" fill="currentColor"><path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-20 bg-[#F8FAFC] border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { stat: '12,000+', label: 'Experts on platform' },
          { stat: '30 days', label: 'Average time to first inbound' },
          { stat: '3–5×', label: 'Fee premium for known experts' },
          { stat: '94%', label: 'User satisfaction rate' },
        ].map(item => (
          <div>
            <p class="text-4xl md:text-5xl font-bold text-[#0F172A] font-mono">{item.stat}</p>
            <p class="mt-2 text-slate-600 text-sm">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-[#0F172A] mb-6">Ready to build your authority?</h2>
      <p class="text-lg text-slate-600 mb-8">Start with your free Visibility Audit and get a personalized roadmap in minutes.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/audit" class="inline-flex items-center justify-center gap-2 bg-[#F97316] text-white font-bold px-8 py-4 rounded-full hover:bg-orange-600 transition-colors shadow-lg text-lg">
          Audit Your Brand
        </a>
        <a href="/pricing" class="inline-flex items-center justify-center border border-slate-300 text-slate-700 font-semibold px-8 py-4 rounded-full hover:border-slate-400 transition-colors text-lg">
          View Pricing
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
