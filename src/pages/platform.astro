---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Platform — GetKnown"
  description="GetKnown is an AI-powered reputation engine designed for the Expert Economy. We provide frameworks, visibility tools, and PR infrastructure that transform quiet professionals into industry icons."
>
  <!-- Hero -->
  <section class="grid min-h-[400px] pt-24 lg:grid-cols-12 lg:pt-0 bg-neutral-950 overflow-hidden">
    <div class="lg:col-span-7 lg:px-12 flex flex-col z-10 pt-12 pr-6 pb-12 pl-6 relative justify-center lg:pt-28">
      <div class="inline-flex gap-2 text-[11px] uppercase font-medium text-blue-400 tracking-wider font-geist bg-blue-500/10 border-blue-500/20 border rounded-full pt-1 pr-3 pb-1 pl-3 items-center w-fit mb-6">
        <iconify-icon icon="solar:stars-linear" width="14" height="14"></iconify-icon>
        The Visibility Platform
      </div>
      <h1 class="leading-[0.95] lg:text-6xl text-5xl text-white tracking-tighter mb-6 font-geist">
        Your complete<br /><span class="text-blue-400">visibility engine.</span>
      </h1>
      <p class="text-lg text-neutral-400 max-w-xl leading-relaxed mb-8 font-geist">
        GetKnown is an AI-powered reputation engine designed for the Expert Economy. We provide the frameworks, visibility tools, and PR infrastructure that transform quiet professionals into industry icons.
      </p>
      <div class="flex items-center gap-4">
        <a href="/audit" class="inline-flex items-center gap-2 bg-blue-600 text-white font-medium px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors shadow-lg font-geist text-sm">
          Start Your Audit
          <iconify-icon icon="solar:arrow-right-up-linear" width="18" height="18"></iconify-icon>
        </a>
        <a href="/pricing" class="inline-flex items-center gap-2 border border-neutral-700 text-neutral-300 font-medium px-6 py-3 rounded-lg hover:border-neutral-500 hover:text-white transition-colors font-geist text-sm">
          View Pricing
        </a>
      </div>
    </div>
    <div class="lg:col-span-5 lg:h-auto overflow-hidden bg-center bg-neutral-800 w-full h-[300px] bg-cover relative" style="background-image: url(https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/71205a4d-4eb6-446d-bbb8-158b16d694bf_800w.webp);">
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-950 via-transparent to-transparent opacity-80"></div>
    </div>
  </section>

  <!-- Stats Band -->
  <section class="bg-blue-600 py-10">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { stat: '12,000+', label: 'Experts on platform' },
          { stat: '30 days', label: 'Avg. time to first inbound' },
          { stat: '3–5×', label: 'Fee premium for known experts' },
          { stat: '94%', label: 'User satisfaction rate' },
        ].map(item => (
          <div>
            <p class="text-3xl md:text-4xl font-semibold text-white font-geist tracking-tight">{item.stat}</p>
            <p class="mt-1 text-blue-200 text-sm font-geist">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Three Pillars -->
  <section class="py-24 bg-white border-t border-neutral-100">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="flex flex-col items-center mb-16">
        <div class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-blue-50 px-4 py-1.5 mb-6">
          <iconify-icon icon="solar:layers-linear" width="16" height="16" class="text-blue-600"></iconify-icon>
          <span class="text-[11px] font-medium uppercase tracking-[0.18em] text-blue-600 font-geist">Core Features</span>
        </div>
        <h2 class="text-4xl lg:text-5xl tracking-tight text-neutral-900 leading-[1.05] font-geist text-center mb-4">
          Three pillars of authority.
        </h2>
        <p class="text-lg text-neutral-500 font-geist text-center max-w-xl">
          Our platform is built on a proven methodology used by category-defining experts worldwide.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Pillar 1: Foundation -->
        <div class="rounded-2xl border border-neutral-100 overflow-hidden shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]">
          <div class="bg-neutral-950 p-8">
            <div class="w-12 h-12 rounded-full bg-blue-600/20 flex items-center justify-center text-blue-400 mb-4 border border-blue-500/30">
              <iconify-icon icon="solar:database-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
            </div>
            <h3 class="text-xl font-semibold text-white font-geist">Personal Brand Foundation</h3>
          </div>
          <div class="p-8 space-y-4 bg-white">
            <p class="text-neutral-500 font-geist text-sm leading-relaxed">Build the bedrock of your authority with our proven positioning framework.</p>
            <ul class="space-y-3">
              {['AI-powered brand audit & gap analysis', 'Category of One positioning workshop', 'LinkedIn profile optimization score', 'Bio & messaging architecture', 'Authority keyword strategy'].map(item => (
                <li class="flex items-start gap-3 text-sm text-neutral-700 font-geist">
                  <iconify-icon icon="solar:check-circle-linear" width="16" height="16" class="text-blue-600 mt-0.5 flex-shrink-0"></iconify-icon>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Pillar 2: Content (Featured) -->
        <div class="rounded-2xl border border-blue-200 overflow-hidden shadow-[0_0_30px_-5px_rgba(37,99,235,0.2)]">
          <div class="bg-blue-600 p-8">
            <div class="flex justify-between items-start mb-4">
              <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center text-white border border-white/30">
                <iconify-icon icon="solar:clapperboard-play-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
              </div>
              <span class="bg-white text-blue-600 text-xs font-semibold px-3 py-1 rounded-full font-geist">Most Popular</span>
            </div>
            <h3 class="text-xl font-semibold text-white font-geist">Content Visibility Engine</h3>
          </div>
          <div class="p-8 space-y-4 bg-white">
            <p class="text-neutral-500 font-geist text-sm leading-relaxed">Automate a multi-channel presence that projects your expertise 24/7.</p>
            <ul class="space-y-3">
              {['AI content calendar & topic generator', 'LinkedIn post & article templates', 'Newsletter system (Authority Weekly)', 'Podcast guesting pitch templates', 'Content repurposing workflows', 'Authority SEO optimization'].map(item => (
                <li class="flex items-start gap-3 text-sm text-neutral-700 font-geist">
                  <iconify-icon icon="solar:check-circle-linear" width="16" height="16" class="text-blue-600 mt-0.5 flex-shrink-0"></iconify-icon>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Pillar 3: PR Scale -->
        <div class="rounded-2xl border border-neutral-100 overflow-hidden shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]">
          <div class="bg-neutral-950 p-8">
            <div class="w-12 h-12 rounded-full bg-blue-600/20 flex items-center justify-center text-blue-400 mb-4 border border-blue-500/30">
              <iconify-icon icon="solar:rocket-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
            </div>
            <h3 class="text-xl font-semibold text-white font-geist">PR & Authority Scaling</h3>
          </div>
          <div class="p-8 space-y-4 bg-white">
            <p class="text-neutral-500 font-geist text-sm leading-relaxed">Bridge into tier-1 media, speaking stages, and high-value networks.</p>
            <ul class="space-y-3">
              {['Tier-1 PR media matching', 'Speaker bureau introduction', 'Podcast host matching algorithm', 'Press kit creation & distribution', 'Analyst & journalist relationship building'].map(item => (
                <li class="flex items-start gap-3 text-sm text-neutral-700 font-geist">
                  <iconify-icon icon="solar:check-circle-linear" width="16" height="16" class="text-blue-600 mt-0.5 flex-shrink-0"></iconify-icon>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="bg-blue-600 py-20">
    <div class="container mx-auto px-6 lg:px-12 text-center">
      <h2 class="text-3xl lg:text-4xl font-semibold text-white tracking-tight font-geist mb-4">Ready to build your authority?</h2>
      <p class="text-lg text-blue-100 mb-8 font-geist max-w-xl mx-auto">Start with your free Visibility Audit and get a personalized roadmap in minutes.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/audit" class="inline-flex items-center justify-center gap-2 bg-white text-blue-600 font-medium px-8 py-3.5 rounded-lg hover:bg-blue-50 transition-colors shadow-lg font-geist">
          Audit Your Authority
          <iconify-icon icon="solar:arrow-right-up-linear" width="18" height="18"></iconify-icon>
        </a>
        <a href="/pricing" class="inline-flex items-center justify-center border border-white/30 text-white font-medium px-8 py-3.5 rounded-lg hover:border-white/60 transition-colors font-geist">
          View Pricing
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
