---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { industries, getIndustry } from '../../data/industries';

export function getStaticPaths() {
  return industries.map(industry => ({
    params: { industry: `how-to-get-known-in-${industry.slug}` },
    props: { guide: industry },
  }));
}

const { guide } = Astro.props;
---

<BaseLayout
  title={`${guide.tagline} — GetKnown`}
  description={`The definitive authority-building guide for ${guide.name} professionals. Discover top podcasts, key metrics, and your "Category of One" framework.`}
>
  <!-- Hero -->
  <section class="bg-[#0F172A] py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 mb-6">
        <a href="/resources" class="text-slate-400 text-sm hover:text-slate-200 transition-colors">Resources</a>
        <span class="text-slate-600">/</span>
        <span class="text-slate-400 text-sm">Industry Guides</span>
        <span class="text-slate-600">/</span>
        <span class="text-[#F97316] text-sm font-semibold">{guide.name}</span>
      </div>
      <div class="inline-flex items-center gap-2 bg-[#F97316]/10 border border-[#F97316]/20 rounded-full px-4 py-1.5 mb-6">
        <span class="text-[#F97316] text-sm font-mono">{guide.marketSize}</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold text-white tracking-tight mb-6">
        {guide.tagline}
      </h1>
      <p class="text-xl text-slate-300 leading-relaxed max-w-2xl">
        {guide.description}
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-[#F8FAFC]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">

      <!-- The Key Challenge -->
      <div class="bg-[#F97316]/5 border border-[#F97316]/20 rounded-xl p-8">
        <h2 class="text-lg font-bold text-[#0F172A] mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#F97316]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
          The Key Challenge in {guide.name}
        </h2>
        <p class="text-slate-700 leading-relaxed">{guide.keyChallenge}</p>
      </div>

      <!-- Category of One -->
      <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-200">
        <span class="text-xs font-mono text-[#F97316] font-semibold uppercase tracking-wider">Your Positioning Framework</span>
        <h2 class="mt-2 text-2xl font-bold text-[#0F172A] mb-4">Your "Category of One" Formula</h2>
        <div class="bg-[#0F172A] rounded-xl p-6">
          <p class="text-slate-300 font-mono text-sm leading-relaxed">{guide.categoryOfOne}</p>
        </div>
        <p class="mt-4 text-sm text-slate-600 leading-relaxed">This positioning makes you specific enough to be remembered and broad enough to be hired. Fill in your unique details to own your niche in {guide.name}.</p>
      </div>

      <!-- Top Podcasts -->
      <div>
        <span class="text-xs font-mono text-[#F97316] font-semibold uppercase tracking-wider">Guesting Flywheel</span>
        <h2 class="mt-2 text-2xl font-bold text-[#0F172A] mb-6">Top 3 Podcasts to Target</h2>
        <div class="space-y-4">
          {guide.podcasts.map((pod, i) => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200 flex gap-6 items-start">
              <div class="w-10 h-10 rounded-full bg-[#F97316] text-white font-bold text-lg flex items-center justify-center flex-shrink-0">
                {i + 1}
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap justify-between items-start gap-2 mb-2">
                  <h3 class="font-bold text-[#0F172A]">{pod.name}</h3>
                  <span class="text-xs font-mono bg-slate-100 text-slate-600 px-3 py-1 rounded-full">{pod.listeners} listeners</span>
                </div>
                <p class="text-sm text-slate-500 mb-3">Hosted by {pod.host}</p>
                <div class="bg-[#F8FAFC] rounded-lg p-3 border-l-2 border-[#F97316]">
                  <p class="text-xs font-semibold text-slate-500 mb-1">Your pitch angle:</p>
                  <p class="text-sm text-slate-700">{pod.pitch}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Authority Metrics -->
      <div>
        <span class="text-xs font-mono text-[#F97316] font-semibold uppercase tracking-wider">KPIs for Authority</span>
        <h2 class="mt-2 text-2xl font-bold text-[#0F172A] mb-6">Key Authority Metrics for {guide.name}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {guide.authorityMetrics.map(m => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
              <h3 class="font-bold text-[#0F172A] text-sm mb-2">{m.metric}</h3>
              <p class="text-xs font-mono text-[#F97316] bg-[#F97316]/5 rounded-lg px-3 py-2 mb-3">{m.benchmark}</p>
              <p class="text-xs text-slate-600 leading-relaxed">{m.tip}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Authority Tips -->
      <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-200">
        <span class="text-xs font-mono text-[#F97316] font-semibold uppercase tracking-wider">Action Plan</span>
        <h2 class="mt-2 text-2xl font-bold text-[#0F172A] mb-6">Your 90-Day Visibility Plan for {guide.name}</h2>
        <ol class="space-y-4">
          {guide.tips.map((tip, i) => (
            <li class="flex items-start gap-4">
              <span class="w-8 h-8 rounded-full bg-[#F97316] text-white text-sm font-bold flex items-center justify-center flex-shrink-0">{i + 1}</span>
              <p class="text-slate-700 leading-relaxed pt-1">{tip}</p>
            </li>
          ))}
        </ol>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[#0F172A]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready to get known in {guide.name}?</h2>
      <p class="text-slate-300 mb-8 text-lg">Start with your free Visibility Scorecard and get your personalized action plan.</p>
      <a href="/audit" class="inline-flex items-center gap-2 bg-[#F97316] text-white font-bold px-8 py-4 rounded-full hover:bg-orange-600 transition-colors shadow-lg text-lg">
        Take the Visibility Scorecard
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9H14M14 9L10 5M14 9L10 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <!-- Other Industries -->
  <section class="py-16 bg-[#F8FAFC]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-[#0F172A] mb-8">Explore Other Industry Guides</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {industries.filter(i => i.slug !== guide.slug).slice(0, 4).map(ind => (
          <a
            href={`/guides/how-to-get-known-in-${ind.slug}`}
            class="bg-white rounded-xl p-4 border border-slate-200 hover:border-[#F97316] hover:shadow-sm transition-all text-center group"
          >
            <p class="font-semibold text-[#0F172A] text-sm group-hover:text-[#F97316] transition-colors">{ind.name}</p>
            <p class="text-xs text-slate-500 mt-1">{ind.marketSize}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
