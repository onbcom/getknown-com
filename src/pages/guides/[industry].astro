---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { industries } from '../../data/industries';

export function getStaticPaths() {
  return industries.map(industry => ({
    params: { industry: `how-to-get-known-in-${industry.slug}` },
    props: { guide: industry },
  }));
}

const { guide } = Astro.props;
---

<BaseLayout
  title={`${guide.tagline} — GetKnown`}
  description={`The definitive authority-building guide for ${guide.name} professionals. Discover top podcasts, key metrics, and your "Category of One" framework.`}
>
  <!-- Hero -->
  <section class="bg-neutral-950 pt-32 pb-16">
    <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
      <div class="flex items-center gap-2 mb-6">
        <a href="/resources" class="text-neutral-400 text-sm hover:text-neutral-200 transition-colors font-geist">Resources</a>
        <span class="text-neutral-700">/</span>
        <span class="text-neutral-400 text-sm font-geist">Industry Guides</span>
        <span class="text-neutral-700">/</span>
        <span class="text-blue-400 text-sm font-medium font-geist">{guide.name}</span>
      </div>
      <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 mb-6">
        <iconify-icon icon="solar:graph-new-up-linear" width="14" height="14" class="text-blue-400"></iconify-icon>
        <span class="text-blue-300 text-xs font-medium font-geist">{guide.marketSize}</span>
      </div>
      <h1 class="text-4xl lg:text-5xl font-semibold text-white tracking-tight mb-6 font-geist leading-[1.05]">
        {guide.tagline}
      </h1>
      <p class="text-lg text-neutral-400 leading-relaxed max-w-2xl font-geist">
        {guide.description}
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-neutral-100/50">
    <div class="container mx-auto px-6 lg:px-12 max-w-4xl space-y-10">

      <!-- The Key Challenge -->
      <div class="bg-blue-50 border border-blue-100 rounded-2xl p-8">
        <h2 class="text-base font-semibold text-neutral-900 mb-3 flex items-center gap-2 font-geist">
          <iconify-icon icon="solar:danger-triangle-linear" width="20" height="20" class="text-blue-600"></iconify-icon>
          The Key Challenge in {guide.name}
        </h2>
        <p class="text-neutral-600 leading-relaxed font-geist text-sm">{guide.keyChallenge}</p>
      </div>

      <!-- Category of One -->
      <div class="bg-white rounded-2xl p-8 shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)] border border-neutral-100">
        <span class="text-xs font-medium text-blue-600 uppercase tracking-wider font-geist">Your Positioning Framework</span>
        <h2 class="mt-2 text-2xl font-semibold text-neutral-900 mb-4 font-geist tracking-tight">Your "Category of One" Formula</h2>
        <div class="bg-neutral-950 rounded-xl p-6">
          <p class="text-neutral-300 font-geist text-sm leading-relaxed">{guide.categoryOfOne}</p>
        </div>
        <p class="mt-4 text-sm text-neutral-500 leading-relaxed font-geist">This positioning makes you specific enough to be remembered and broad enough to be hired. Fill in your unique details to own your niche in {guide.name}.</p>
      </div>

      <!-- Top Podcasts -->
      <div>
        <span class="text-xs font-medium text-blue-600 uppercase tracking-wider font-geist">Guesting Flywheel</span>
        <h2 class="mt-2 text-2xl font-semibold text-neutral-900 mb-6 font-geist tracking-tight">Top 3 Podcasts to Target</h2>
        <div class="space-y-4">
          {guide.podcasts.map((pod, i) => (
            <div class="bg-white rounded-2xl p-6 shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)] border border-neutral-100 flex gap-6 items-start">
              <div class="w-10 h-10 rounded-full bg-blue-600 text-white font-semibold text-lg flex items-center justify-center flex-shrink-0 font-geist">
                {i + 1}
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap justify-between items-start gap-2 mb-2">
                  <h3 class="font-semibold text-neutral-900 font-geist">{pod.name}</h3>
                  <span class="text-xs font-geist bg-neutral-100 text-neutral-600 px-3 py-1 rounded-full">{pod.listeners} listeners</span>
                </div>
                <p class="text-sm text-neutral-500 mb-3 font-geist">Hosted by {pod.host}</p>
                <div class="bg-blue-50 rounded-xl p-3 border-l-2 border-blue-600">
                  <p class="text-xs font-medium text-neutral-500 mb-1 font-geist">Your pitch angle:</p>
                  <p class="text-sm text-neutral-700 font-geist">{pod.pitch}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Authority Metrics -->
      <div>
        <span class="text-xs font-medium text-blue-600 uppercase tracking-wider font-geist">KPIs for Authority</span>
        <h2 class="mt-2 text-2xl font-semibold text-neutral-900 mb-6 font-geist tracking-tight">Key Authority Metrics for {guide.name}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {guide.authorityMetrics.map(m => (
            <div class="bg-white rounded-2xl p-6 shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)] border border-neutral-100">
              <h3 class="font-semibold text-neutral-900 text-sm mb-2 font-geist">{m.metric}</h3>
              <p class="text-xs text-blue-600 bg-blue-50 rounded-lg px-3 py-2 mb-3 font-geist">{m.benchmark}</p>
              <p class="text-xs text-neutral-500 leading-relaxed font-geist">{m.tip}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Authority Tips -->
      <div class="bg-white rounded-2xl p-8 shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)] border border-neutral-100">
        <span class="text-xs font-medium text-blue-600 uppercase tracking-wider font-geist">Action Plan</span>
        <h2 class="mt-2 text-2xl font-semibold text-neutral-900 mb-6 font-geist tracking-tight">Your 90-Day Visibility Plan for {guide.name}</h2>
        <ol class="space-y-4">
          {guide.tips.map((tip, i) => (
            <li class="flex items-start gap-4">
              <span class="w-8 h-8 rounded-full bg-blue-600 text-white text-sm font-medium flex items-center justify-center flex-shrink-0 font-geist">{i + 1}</span>
              <p class="text-neutral-600 leading-relaxed pt-1 font-geist text-sm">{tip}</p>
            </li>
          ))}
        </ol>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-blue-600 py-16">
    <div class="container mx-auto px-6 lg:px-12 text-center max-w-3xl">
      <h2 class="text-3xl font-semibold text-white mb-4 font-geist tracking-tight">Ready to get known in {guide.name}?</h2>
      <p class="text-blue-100 mb-8 font-geist">Start with your free Visibility Scorecard and get your personalized action plan.</p>
      <a href="/audit" class="inline-flex items-center gap-2 bg-white text-blue-600 font-medium px-8 py-4 rounded-lg hover:bg-blue-50 transition-colors shadow-lg font-geist">
        Take the Visibility Scorecard
        <iconify-icon icon="solar:arrow-right-up-linear" width="18" height="18"></iconify-icon>
      </a>
    </div>
  </section>

  <!-- Other Industries -->
  <section class="py-16 bg-neutral-100/50 border-t border-neutral-200">
    <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
      <h2 class="text-2xl font-semibold text-neutral-900 mb-8 font-geist tracking-tight">Explore Other Industry Guides</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {industries.filter(i => i.slug !== guide.slug).slice(0, 4).map(ind => (
          <a
            href={`/guides/how-to-get-known-in-${ind.slug}`}
            class="bg-white rounded-2xl p-4 border border-neutral-100 hover:border-blue-200 hover:bg-blue-50/50 hover:shadow-sm transition-all text-center group shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]"
          >
            <p class="font-medium text-neutral-900 text-sm group-hover:text-blue-600 transition-colors font-geist">{ind.name}</p>
            <p class="text-xs text-neutral-400 mt-1 font-geist">{ind.marketSize}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
