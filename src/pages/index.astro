---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="GetKnown | Become the Authority in Your Industry"
  description="The premier visibility platform for founders and experts to build their personal brand and authority in 2026."
>

  <!-- Hero Section -->
  <section class="grid min-h-[600px] pt-24 lg:grid-cols-12 lg:pt-0">

    <!-- Left Content -->
    <div class="lg:col-span-7 lg:px-12 flex flex-col z-10 pt-12 pr-6 pb-12 pl-6 relative justify-center">

      <!-- Eyebrow -->
      <div class="flex lg:mt-28 w-fit mt-0 mb-6 gap-x-2 gap-y-2 items-center">
        <div class="inline-flex gap-2 text-[11px] uppercase font-medium text-blue-600 tracking-wider font-geist bg-blue-50 border-blue-100 border rounded-full pt-1 pr-3 pb-1 pl-3 gap-x-2 gap-y-2 items-center">
          <span class="relative flex h-1.5 w-1.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-blue-500"></span>
          </span>
          Accepting New Experts for 2026
        </div>
      </div>

      <h1 class="leading-[0.95] lg:text-7xl text-6xl text-neutral-900 tracking-tighter mb-8">
        <span class="block font-geist">Get known for</span>
        <span class="block font-geist ml-2 text-blue-600">what you do.</span>
      </h1>

      <p class="text-lg text-neutral-500 max-w-xl leading-relaxed mb-10 font-normal font-geist">
        You've spent years mastering your craft. Now, let's make sure the world knows it. Build a category-defining personal brand, scale your visibility, and attract high-value opportunities on autopilot in 2026.
      </p>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-8 mb-16">
        <a href="/audit" class="group shadow-blue-500/30 hover:shadow-blue-500/60 transition-all duration-300 overflow-hidden hover:bg-blue-700 font-medium text-white bg-blue-600 rounded-lg pt-4 pr-8 pb-4 pl-8 relative shadow-lg" style="box-shadow:0 18px 40px -15px rgba(37,99,235,0.85), inset 0 2px 4px rgba(255,255,255,0.2); border-radius:0.5rem; position: relative; --border-gradient: linear-gradient(180deg, rgba(147, 197, 253, 0.4), rgba(37, 99, 235, 0.5)); --border-radius-before: 8px">
          <div class="group-hover:translate-y-0 group-hover:opacity-0 transition-all duration-300 bg-white/10 absolute top-0 right-0 bottom-0 left-0 translate-y-full"></div>
          <span class="flex items-center gap-2 relative font-geist">Audit Your Authority <iconify-icon icon="solar:arrow-right-up-linear" stroke-width="1.5" width="18" height="18" class="group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300"></iconify-icon></span>
        </a>

        <div class="flex items-center gap-4">
          <div class="flex -space-x-3">
            <img src="https://i.pravatar.cc/100?img=32" alt="User" class="w-10 h-10 rounded-full border-2 border-white" />
            <img src="https://i.pravatar.cc/100?img=53" alt="User" class="w-10 h-10 rounded-full border-2 border-white" />
            <img src="https://i.pravatar.cc/100?img=68" alt="User" class="w-10 h-10 rounded-full border-2 border-white" />
          </div>
          <div class="text-xs font-medium text-neutral-600 font-geist">
            <div class="flex items-center text-yellow-500 mb-0.5 gap-0.5">
              <iconify-icon icon="solar:star-linear" width="14" height="14" stroke-width="1.5"></iconify-icon>
              <iconify-icon icon="solar:star-linear" width="14" height="14" stroke-width="1.5"></iconify-icon>
              <iconify-icon icon="solar:star-linear" width="14" height="14" stroke-width="1.5"></iconify-icon>
              <iconify-icon icon="solar:star-linear" width="14" height="14" stroke-width="1.5"></iconify-icon>
              <iconify-icon icon="solar:star-linear" width="14" height="14" stroke-width="1.5"></iconify-icon>
            </div>
            Trusted by 50+ Industry Leaders
          </div>
        </div>
      </div>

      <div class="flex flex-wrap hover:grayscale-0 transition-all duration-500 text-neutral-800 opacity-60 mb-12 grayscale gap-x-8 gap-y-8 items-center">
        <iconify-icon icon="simple-icons:forbes" width="28" height="28"></iconify-icon>
        <iconify-icon icon="simple-icons:bloomberg" width="28" height="28"></iconify-icon>
        <iconify-icon icon="simple-icons:fastcompany" width="28" height="28"></iconify-icon>
        <iconify-icon icon="simple-icons:wsj" width="28" height="28"></iconify-icon>
      </div>
    </div>

    <!-- Right Visual -->
    <div class="lg:col-span-5 lg:h-auto overflow-hidden bg-center bg-neutral-900 w-full h-[500px] bg-cover relative bg-[url(https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/122547d3-40ef-497e-a00d-f533aa8ef763_1600w.webp)]">
      <div class="absolute inset-0 bg-gradient-to-t from-neutral-900 via-transparent to-transparent opacity-60"></div>
    </div>
  </section>

  <!-- Blue Value Prop Section -->
  <section class="bg-blue-600 border-blue-600 border-t">
    <div class="flex flex-col lg:flex-row lg:px-12 lg:pt-28 lg:pb-28 pt-20 pr-6 pb-20 pl-6 gap-x-12 gap-y-12 items-center">

      <!-- Services Column (Marquee) -->
      <div class="w-full overflow-hidden space-y-12">
        <p class="text-2xl lg:text-3xl text-white leading-snug tracking-tight max-w-3xl font-geist mx-auto text-center">
          We engineer the transition from <span class="text-blue-200 font-bold font-geist">Invisible Expert</span> to a recognized Category of One.
        </p>

        <div class="w-full mask-gradient no-scrollbar mt-12 overflow-x-hidden">
          <div class="flex gap-6 animate-marquee" style="width: max-content;">
            <!-- Card 1: Audit -->
            <div class="flex-none w-[260px] bg-blue-700 p-6 rounded-2xl shadow-sm flex flex-col h-64 group hover:bg-blue-800 transition-colors duration-300">
              <div class="flex transition-colors duration-300 text-white bg-white/10 w-10 h-10 rounded-lg mb-0 items-center justify-center">
                <iconify-icon icon="solar:scanner-linear" width="22" height="22" stroke-width="1.5"></iconify-icon>
              </div>
              <h4 class="text-lg font-semibold text-white leading-tight mt-6 mb-2 font-geist">Audit</h4>
              <p class="text-blue-100 text-sm font-geist leading-relaxed mb-4">Scan your digital footprint with our AI engine to uncover authority gaps.</p>
              <div class="mt-auto w-full">
                <a href="/audit" class="block text-center font-medium text-white bg-white/10 rounded-lg py-2.5 px-4 w-full text-sm hover:bg-white/20 transition-colors">
                  <span class="relative flex items-center justify-center gap-2 font-geist">
                    Scan Profile
                    <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                  </span>
                </a>
              </div>
            </div>

            <!-- Card 2: Define -->
            <div class="flex-none w-[260px] bg-blue-700 p-6 rounded-2xl shadow-sm flex flex-col h-64 group hover:bg-blue-800 transition-colors duration-300">
              <div class="flex transition-colors duration-300 text-white bg-white/10 w-10 h-10 rounded-lg mb-0 items-center justify-center">
                <iconify-icon icon="solar:pen-new-square-linear" width="22" height="22" stroke-width="1.5"></iconify-icon>
              </div>
              <h4 class="text-lg font-semibold text-white leading-tight mt-6 mb-2 font-geist">Define</h4>
              <p class="text-blue-100 text-sm font-geist leading-relaxed mb-4">Carve out a "Category of One" to instantly differentiate your expertise.</p>
              <div class="mt-auto w-full">
                <a href="/platform" class="block text-center font-medium text-white bg-white/10 rounded-lg py-2.5 px-4 w-full text-sm hover:bg-white/20 transition-colors">
                  <span class="relative flex items-center justify-center gap-2 font-geist">
                    Find Niche
                    <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                  </span>
                </a>
              </div>
            </div>

            <!-- Card 3: Automate -->
            <div class="flex-none w-[260px] bg-blue-700 p-6 rounded-2xl shadow-sm flex flex-col h-64 group hover:bg-blue-800 transition-colors duration-300">
              <div class="flex transition-colors duration-300 text-white bg-white/10 w-10 h-10 rounded-lg mb-0 items-center justify-center">
                <iconify-icon icon="solar:settings-linear" width="22" height="22" stroke-width="1.5"></iconify-icon>
              </div>
              <h4 class="text-lg font-semibold text-white leading-tight mt-6 mb-2 font-geist">Automate</h4>
              <p class="text-blue-100 text-sm font-geist leading-relaxed mb-4">Deploy a multi-channel content strategy seamlessly without the grind.</p>
              <div class="mt-auto w-full">
                <a href="/platform" class="block text-center font-medium text-white bg-white/10 rounded-lg py-2.5 px-4 w-full text-sm hover:bg-white/20 transition-colors">
                  <span class="relative flex items-center justify-center gap-2 font-geist">
                    Build Systems
                    <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                  </span>
                </a>
              </div>
            </div>

            <!-- Card 4: Scale -->
            <div class="flex-none w-[260px] bg-blue-700 p-6 rounded-2xl shadow-sm flex flex-col h-64 group hover:bg-blue-800 transition-colors duration-300">
              <div class="flex transition-colors duration-300 text-white bg-white/10 w-10 h-10 rounded-lg mb-0 items-center justify-center">
                <iconify-icon icon="solar:rocket-linear" width="22" height="22" stroke-width="1.5"></iconify-icon>
              </div>
              <h4 class="text-lg font-semibold text-white leading-tight mt-6 mb-2 font-geist">Scale</h4>
              <p class="text-blue-100 text-sm font-geist leading-relaxed mb-4">Move confidently into tier-1 PR placements and keynote speaking circuits.</p>
              <div class="mt-auto w-full">
                <a href="/platform" class="block text-center font-medium text-white bg-white/10 rounded-lg py-2.5 px-4 w-full text-sm hover:bg-white/20 transition-colors">
                  <span class="relative flex items-center justify-center gap-2 font-geist">
                    Go Big
                    <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                  </span>
                </a>
              </div>
            </div>

            <!-- Duplicate set for seamless marquee -->
            <div class="flex-none w-[260px] bg-blue-700 p-6 rounded-2xl shadow-sm flex flex-col h-64 group hover:bg-blue-800 transition-colors duration-300">
              <div class="flex transition-colors duration-300 text-white bg-white/10 w-10 h-10 rounded-lg mb-0 items-center justify-center">
                <iconify-icon icon="solar:scanner-linear" width="22" height="22" stroke-width="1.5"></iconify-icon>
              </div>
              <h4 class="text-lg font-semibold text-white leading-tight mt-6 mb-2 font-geist">Audit</h4>
              <p class="text-blue-100 text-sm font-geist leading-relaxed mb-4">Scan your digital footprint with our AI engine to uncover authority gaps.</p>
              <div class="mt-auto w-full">
                <a href="/audit" class="block text-center font-medium text-white bg-white/10 rounded-lg py-2.5 px-4 w-full text-sm hover:bg-white/20 transition-colors">
                  <span class="relative flex items-center justify-center gap-2 font-geist">
                    Scan Profile
                    <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                  </span>
                </a>
              </div>
            </div>
            <div class="flex-none w-[260px] bg-blue-700 p-6 rounded-2xl shadow-sm flex flex-col h-64 group hover:bg-blue-800 transition-colors duration-300">
              <div class="flex transition-colors duration-300 text-white bg-white/10 w-10 h-10 rounded-lg mb-0 items-center justify-center">
                <iconify-icon icon="solar:pen-new-square-linear" width="22" height="22" stroke-width="1.5"></iconify-icon>
              </div>
              <h4 class="text-lg font-semibold text-white leading-tight mt-6 mb-2 font-geist">Define</h4>
              <p class="text-blue-100 text-sm font-geist leading-relaxed mb-4">Carve out a "Category of One" to instantly differentiate your expertise.</p>
              <div class="mt-auto w-full">
                <a href="/platform" class="block text-center font-medium text-white bg-white/10 rounded-lg py-2.5 px-4 w-full text-sm hover:bg-white/20 transition-colors">
                  <span class="relative flex items-center justify-center gap-2 font-geist">
                    Find Niche
                    <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                  </span>
                </a>
              </div>
            </div>
            <div class="flex-none w-[260px] bg-blue-700 p-6 rounded-2xl shadow-sm flex flex-col h-64 group hover:bg-blue-800 transition-colors duration-300">
              <div class="flex transition-colors duration-300 text-white bg-white/10 w-10 h-10 rounded-lg mb-0 items-center justify-center">
                <iconify-icon icon="solar:settings-linear" width="22" height="22" stroke-width="1.5"></iconify-icon>
              </div>
              <h4 class="text-lg font-semibold text-white leading-tight mt-6 mb-2 font-geist">Automate</h4>
              <p class="text-blue-100 text-sm font-geist leading-relaxed mb-4">Deploy a multi-channel content strategy seamlessly without the grind.</p>
              <div class="mt-auto w-full">
                <a href="/platform" class="block text-center font-medium text-white bg-white/10 rounded-lg py-2.5 px-4 w-full text-sm hover:bg-white/20 transition-colors">
                  <span class="relative flex items-center justify-center gap-2 font-geist">
                    Build Systems
                    <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                  </span>
                </a>
              </div>
            </div>
            <div class="flex-none w-[260px] bg-blue-700 p-6 rounded-2xl shadow-sm flex flex-col h-64 group hover:bg-blue-800 transition-colors duration-300">
              <div class="flex transition-colors duration-300 text-white bg-white/10 w-10 h-10 rounded-lg mb-0 items-center justify-center">
                <iconify-icon icon="solar:rocket-linear" width="22" height="22" stroke-width="1.5"></iconify-icon>
              </div>
              <h4 class="text-lg font-semibold text-white leading-tight mt-6 mb-2 font-geist">Scale</h4>
              <p class="text-blue-100 text-sm font-geist leading-relaxed mb-4">Move confidently into tier-1 PR placements and keynote speaking circuits.</p>
              <div class="mt-auto w-full">
                <a href="/platform" class="block text-center font-medium text-white bg-white/10 rounded-lg py-2.5 px-4 w-full text-sm hover:bg-white/20 transition-colors">
                  <span class="relative flex items-center justify-center gap-2 font-geist">
                    Go Big
                    <iconify-icon icon="solar:arrow-right-linear" width="16" height="16"></iconify-icon>
                  </span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sovereign Expert Advantage Section -->
  <section class="overflow-hidden bg-neutral-100/50 border-neutral-200 border-t pt-24 pb-24 relative">
    <div class="container mx-auto px-6 lg:px-12 relative z-10">
      <!-- Section Header -->
      <div class="flex flex-col lg:flex-row justify-between items-start mb-20 gap-10">
        <div class="max-w-3xl">
          <h2 class="text-4xl lg:text-5xl tracking-tight text-neutral-900 leading-[1.05] font-geist mb-4">
            The Sovereign Expert Advantage
          </h2>
          <p class="text-lg text-neutral-500 font-geist">Focus on Inbound Opportunities, Pricing Power, and Network Equity.</p>
        </div>
        <a href="/platform" class="group flex items-center gap-2 text-sm font-medium text-blue-600 border-b border-transparent pb-1 hover:border-blue-600 transition-all mt-2 font-geist">
          Unlock Your Advantage
          <iconify-icon icon="solar:arrow-right-up-linear" stroke-width="1.5" width="20" height="20"></iconify-icon>
        </a>
      </div>

      <!-- Grid Layout 3 cols -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-6">

        <!-- Card 1: Inbound Opportunities -->
        <div class="bg-white p-8 rounded-2xl flex flex-col justify-between h-[520px] shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)] transition-colors border border-neutral-100">
          <div>
            <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 mb-6">
              <iconify-icon icon="solar:magnet-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
            </div>
            <h3 class="text-2xl font-semibold text-neutral-900 mb-4 leading-tight tracking-tight font-geist">
              Inbound Opportunities
            </h3>
            <p class="text-neutral-500 leading-relaxed text-base font-geist">
              Stop chasing cold leads. By establishing absolute authority in your niche, high-value deals, partnerships, and speaking engagements start coming directly to you.
            </p>
          </div>
          <div class="mt-8 border-t border-neutral-100 pt-6">
            <div class="flex items-center gap-3">
              <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/917d6f93-fb36-439a-8c48-884b67b35381_1600w.jpg" alt="Sarah Jenkins" class="w-10 h-10 rounded-full object-cover" />
              <div>
                <div class="text-sm font-semibold text-neutral-900 leading-none mb-1 font-geist">Sarah Jenkins</div>
                <div class="text-xs text-neutral-400 font-medium font-geist">Founder, ScaleAI</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 2: Brand Image -->
        <div class="relative rounded-2xl overflow-hidden h-[520px] group bg-neutral-900 shadow-lg border border-neutral-800">
          <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/71205a4d-4eb6-446d-bbb8-158b16d694bf_800w.webp" alt="Pricing Power" class="transition-transform duration-1000 group-hover:scale-110 group-hover:opacity-100 opacity-60 w-full h-full object-cover absolute top-0 right-0 bottom-0 left-0" />
          <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-transparent to-black/80"></div>
          <div class="flex flex-col z-10 text-white pt-8 pr-8 pb-8 pl-8 absolute top-0 right-0 bottom-0 left-0 justify-between">
            <div class="flex justify-between items-start">
              <span class="text-sm font-medium tracking-wide font-geist text-blue-300">Category of One</span>
            </div>
            <div>
              <h3 class="text-3xl font-semibold text-white mb-2 leading-tight tracking-tight font-geist">
                Pricing Power
              </h3>
              <p class="text-neutral-300 text-sm font-geist">Authority removes you from the commodity trap, allowing you to command premium rates without friction.</p>
            </div>
          </div>
        </div>

        <!-- Card 3: Network Equity / Authority Score -->
        <div class="bg-white p-8 rounded-2xl flex flex-col items-center justify-between h-[520px] shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)] transition-colors relative overflow-hidden group border border-neutral-100">
          <!-- Decorative Background Rings -->
          <div class="absolute inset-0 pointer-events-none opacity-[0.03]">
            <svg viewBox="0 0 100 100" class="w-full h-full stroke-neutral-900 fill-none" stroke-width="0.5">
              <circle cx="50" cy="50" r="20"></circle>
              <circle cx="50" cy="50" r="35"></circle>
              <circle cx="50" cy="50" r="48"></circle>
            </svg>
          </div>

          <div class="text-center relative z-10 mt-4">
            <span class="text-sm text-blue-600 font-medium block mb-2 font-geist">Network Equity</span>
            <span class="text-2xl font-semibold text-neutral-900 tracking-tight font-geist">Authority Score</span>
          </div>

          <!-- Circle Chart -->
          <div class="relative w-56 h-56 flex items-center justify-center">
            <div class="flex flex-col absolute top-0 right-0 bottom-0 left-0 items-center justify-center">
              <div class="text-5xl text-neutral-900 tracking-tighter mb-8 font-geist">+142%</div>
            </div>
          </div>

          <a href="/audit" class="w-full bg-blue-600 text-white text-sm font-medium py-3.5 rounded-lg hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-500/20 transition-all duration-300 transform group-hover:-translate-y-1 font-geist text-center block">
            Calculate Your Score
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Authority Flywheel Dark Section -->
  <section class="overflow-hidden bg-neutral-950 border-neutral-800 border-t pt-24 pb-24 relative">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-neutral-800/20 via-neutral-950 to-neutral-950"></div>

    <div class="container mx-auto px-6 lg:px-12 relative z-10">
      <!-- Label -->
      <div class="flex flex-col items-center mb-14">
        <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 shadow-sm mb-6">
          <iconify-icon icon="solar:infinity-linear" width="18" height="18" stroke-width="1.5" class="text-blue-400"></iconify-icon>
          <span class="text-[11px] font-medium uppercase tracking-[0.18em] text-blue-300 font-geist">
            The Authority Flywheel
          </span>
        </div>
        <h2 class="text-4xl lg:text-5xl tracking-tight text-white text-center max-w-3xl leading-[1.05] font-geist">
          A systematic approach to being seen by the right people.
        </h2>
      </div>

      <!-- Problem Grid (Dark Mode) - 3 columns -->
      <div class="relative mt-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 relative gap-x-6 gap-y-6">
          <!-- Column 1: Foundations -->
          <div class="flex flex-col gap-4">
            <div class="h-16 rounded-2xl border border-dashed border-white/10 bg-white/[0.02] p-5 flex flex-col justify-center gap-2.5 opacity-50">
              <div class="h-1 w-12 rounded-full bg-white/10"></div>
            </div>
            <div class="rounded-2xl bg-neutral-900 border border-neutral-800 shadow-2xl p-8 flex flex-col h-full justify-start hover:border-neutral-700 transition-colors">
              <div class="w-12 h-12 rounded-full bg-neutral-800 flex items-center justify-center text-blue-400 mb-6 border border-neutral-700">
                <iconify-icon icon="solar:database-linear" width="24" height="24" stroke-width="1.5"></iconify-icon>
              </div>
              <h3 class="text-xl font-semibold text-white mb-3 font-geist tracking-tight">Foundations</h3>
              <p class="text-base text-neutral-400 leading-relaxed font-geist">
                Personal branding basics. Optimize your existing profiles, website, and digital footprint for the 2026 AI-search era.
              </p>
            </div>
            <div class="h-16 rounded-2xl border border-dashed border-white/10 bg-white/[0.02] p-5 flex flex-col justify-center gap-2.5 opacity-50">
              <div class="h-1 w-20 rounded-full bg-white/10"></div>
            </div>
          </div>

          <!-- Column 2: Content Engine -->
          <div class="flex flex-col gap-4 pt-6 md:pt-0">
            <div class="h-20 rounded-2xl border border-dashed border-white/10 bg-white/[0.02] p-5 flex flex-col justify-center gap-2.5 opacity-50">
              <div class="h-1 w-16 rounded-full bg-white/10"></div>
              <div class="h-1 w-2/3 rounded-full bg-white/5"></div>
            </div>
            <div class="rounded-2xl bg-neutral-900 border border-blue-900/30 shadow-[0_0_30px_-5px_rgba(37,99,235,0.15)] p-8 flex flex-col h-full justify-start relative overflow-hidden group">
              <div class="absolute inset-0 bg-gradient-to-br from-blue-600/5 to-transparent"></div>
              <div class="relative z-10">
                <div class="w-12 h-12 rounded-full bg-blue-600/20 flex items-center justify-center text-blue-400 mb-6 border border-blue-500/30">
