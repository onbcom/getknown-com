---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const allArticles = (await getCollection('articles'))
  .filter(a => a.slug !== article.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout
  title={`${article.data.title} — GetKnown`}
  description={article.data.summary}
>
  <!-- Article Header -->
  <section class="bg-neutral-950 pt-32 pb-16">
    <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
      <div class="flex items-center gap-2 mb-6">
        <a href="/resources" class="text-neutral-400 text-sm hover:text-neutral-200 transition-colors font-geist">Resources</a>
        <span class="text-neutral-700">/</span>
        <span class="text-neutral-400 text-sm truncate font-geist">{article.data.title}</span>
      </div>

      <div class="flex flex-wrap gap-2 mb-6">
        {article.data.tags?.map(tag => (
          <span class="bg-blue-500/10 text-blue-400 text-xs font-medium px-3 py-1 rounded-full capitalize border border-blue-500/20 font-geist">{tag}</span>
        ))}
      </div>

      <h1 class="text-3xl lg:text-5xl font-semibold text-white leading-tight tracking-tight mb-6 font-geist">
        {article.data.title}
      </h1>

      <p class="text-lg text-neutral-400 leading-relaxed mb-8 max-w-3xl font-geist">
        {article.data.summary}
      </p>

      <div class="flex items-center gap-4 pt-6 border-t border-neutral-800">
        <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-medium font-geist text-sm">GK</div>
        <div>
          <p class="text-white font-medium text-sm font-geist">{article.data.author}</p>
          <p class="text-neutral-500 text-xs font-geist">
            {new Date(article.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-12">
        <!-- Main content -->
        <article class="prose prose-neutral prose-lg max-w-none
          prose-headings:font-geist prose-headings:font-semibold prose-headings:text-neutral-900 prose-headings:tracking-tight
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-neutral-600 prose-p:leading-relaxed prose-p:font-geist
          prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
          prose-strong:text-neutral-900
          prose-ul:text-neutral-600 prose-ol:text-neutral-600
          prose-li:marker:text-blue-600 prose-li:font-geist
          prose-blockquote:border-l-blue-600 prose-blockquote:bg-blue-50 prose-blockquote:py-3 prose-blockquote:pr-4 prose-blockquote:not-italic
          prose-code:text-blue-600 prose-code:bg-neutral-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-geist
        ">
          <Content />
        </article>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <div class="bg-neutral-50 rounded-2xl p-6 border border-neutral-100 sticky top-24 shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]">
            <h3 class="text-sm font-semibold text-neutral-900 mb-4 font-geist">Take the Next Step</h3>
            <p class="text-sm text-neutral-500 mb-5 leading-relaxed font-geist">Get your personalized Visibility Score and action plan in 2 minutes.</p>
            <a href="/audit" class="block w-full text-center bg-blue-600 text-white font-medium py-3 rounded-lg hover:bg-blue-700 transition-colors text-sm font-geist">
              Audit Your Authority
            </a>
            <div class="mt-5 pt-5 border-t border-neutral-100">
              <p class="text-xs font-medium text-neutral-500 mb-3 font-geist uppercase tracking-wider">Share this article</p>
              <div class="flex gap-2">
                <a href="#" class="flex-1 flex items-center justify-center gap-1.5 bg-white border border-neutral-200 rounded-lg py-2 text-xs font-medium text-neutral-600 hover:bg-neutral-50 transition-colors font-geist">
                  <iconify-icon icon="simple-icons:linkedin" width="12" height="12"></iconify-icon>
                  LinkedIn
                </a>
                <a href="#" class="flex-1 flex items-center justify-center gap-1.5 bg-white border border-neutral-200 rounded-lg py-2 text-xs font-medium text-neutral-600 hover:bg-neutral-50 transition-colors font-geist">
                  <iconify-icon icon="simple-icons:x" width="12" height="12"></iconify-icon>
                  X
                </a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- More Articles -->
  {allArticles.length > 0 && (
    <section class="py-16 bg-neutral-100/50 border-t border-neutral-200">
      <div class="container mx-auto px-6 lg:px-12">
        <h2 class="text-2xl font-semibold text-neutral-900 mb-8 font-geist tracking-tight">More from GetKnown</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {allArticles.map(a => (
            <a href={`/resources/${a.slug}`} class="bg-white rounded-2xl p-6 border border-neutral-100 hover:shadow-[0_4px_20px_-4px_rgba(0,0,0,0.1)] hover:border-blue-200 transition-all group shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]">
              <div class="flex flex-wrap gap-2 mb-3">
                {a.data.tags?.slice(0, 1).map(tag => (
                  <span class="bg-neutral-100 text-neutral-600 text-xs px-3 py-1 rounded-full capitalize font-geist">{tag}</span>
                ))}
              </div>
              <h3 class="font-semibold text-neutral-900 text-sm leading-snug mb-2 group-hover:text-blue-600 transition-colors font-geist">{a.data.title}</h3>
              <p class="text-xs text-neutral-400 font-geist">{new Date(a.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
