---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const allArticles = (await getCollection('articles'))
  .filter(a => a.slug !== article.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout
  title={`${article.data.title} — GetKnown`}
  description={article.data.summary}
>
  <!-- Article Header -->
  <section class="bg-[#0F172A] py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 mb-6">
        <a href="/resources" class="text-slate-400 text-sm hover:text-slate-200 transition-colors">Resources</a>
        <span class="text-slate-600">/</span>
        <span class="text-slate-400 text-sm truncate">{article.data.title}</span>
      </div>

      <div class="flex flex-wrap gap-2 mb-6">
        {article.data.tags?.map(tag => (
          <span class="bg-[#F97316]/10 text-[#F97316] text-xs font-medium px-3 py-1 rounded-full capitalize border border-[#F97316]/20">{tag}</span>
        ))}
      </div>

      <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight tracking-tight mb-6">
        {article.data.title}
      </h1>

      <p class="text-xl text-slate-300 leading-relaxed mb-8 max-w-3xl">
        {article.data.summary}
      </p>

      <div class="flex items-center gap-4 pt-6 border-t border-slate-700">
        <div class="w-10 h-10 rounded-full bg-[#F97316] flex items-center justify-center text-white font-bold">GK</div>
        <div>
          <p class="text-white font-semibold text-sm">{article.data.author}</p>
          <p class="text-slate-400 text-xs">
            {new Date(article.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12">
        <!-- Main content -->
        <article class="prose prose-slate prose-lg max-w-none
          prose-headings:font-bold prose-headings:text-[#0F172A] prose-headings:tracking-tight
          prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-slate-700 prose-p:leading-relaxed
          prose-a:text-[#F97316] prose-a:no-underline hover:prose-a:underline
          prose-strong:text-[#0F172A]
          prose-ul:text-slate-700 prose-ol:text-slate-700
          prose-li:marker:text-[#F97316]
          prose-blockquote:border-l-[#F97316] prose-blockquote:bg-[#F8FAFC] prose-blockquote:py-3 prose-blockquote:pr-4
          prose-code:text-[#F97316] prose-code:bg-slate-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
          prose-table:text-sm
          prose-th:bg-slate-50 prose-th:text-[#0F172A]
        ">
          <Content />
        </article>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <div class="bg-[#F8FAFC] rounded-xl p-6 border border-slate-200 sticky top-24">
            <h3 class="text-sm font-bold text-[#0F172A] mb-4">Take the Next Step</h3>
            <p class="text-sm text-slate-600 mb-5 leading-relaxed">Get your personalized Visibility Score and action plan in 2 minutes.</p>
            <a href="/audit" class="block w-full text-center bg-[#F97316] text-white font-bold py-3 rounded-full hover:bg-orange-600 transition-colors text-sm">
              Audit Your Authority
            </a>
            <div class="mt-5 pt-5 border-t border-slate-200">
              <p class="text-xs font-semibold text-slate-500 mb-3">SHARE THIS ARTICLE</p>
              <div class="flex gap-2">
                <a href="#" class="flex-1 flex items-center justify-center gap-1.5 bg-white border border-slate-200 rounded-lg py-2 text-xs font-medium text-slate-600 hover:bg-slate-50 transition-colors">
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
                  LinkedIn
                </a>
                <a href="#" class="flex-1 flex items-center justify-center gap-1.5 bg-white border border-slate-200 rounded-lg py-2 text-xs font-medium text-slate-600 hover:bg-slate-50 transition-colors">
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  X
                </a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- More Articles -->
  {allArticles.length > 0 && (
    <section class="py-16 bg-[#F8FAFC] border-t border-slate-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-[#0F172A] mb-8">More from GetKnown</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {allArticles.map(a => (
            <a href={`/resources/${a.slug}`} class="bg-white rounded-xl p-6 border border-slate-200 hover:shadow-md hover:border-[#F97316]/30 transition-all group">
              <div class="flex flex-wrap gap-2 mb-3">
                {a.data.tags?.slice(0, 1).map(tag => (
                  <span class="bg-slate-100 text-slate-600 text-xs px-3 py-1 rounded-full capitalize">{tag}</span>
                ))}
              </div>
              <h3 class="font-bold text-[#0F172A] text-sm leading-snug mb-2 group-hover:text-[#F97316] transition-colors">{a.data.title}</h3>
              <p class="text-xs text-slate-400">{new Date(a.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
