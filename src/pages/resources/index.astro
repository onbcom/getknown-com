---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const industries = [
  { slug: 'tech', name: 'Tech' },
  { slug: 'finance', name: 'Finance' },
  { slug: 'health', name: 'Health & Wellness' },
  { slug: 'consulting', name: 'Consulting' },
  { slug: 'real-estate', name: 'Real Estate' },
];
---

<BaseLayout
  title="Resources & Articles — GetKnown"
  description="Strategic articles on personal branding, authority building, LinkedIn, podcast guesting, SEO, and more. Build your expert visibility in 2026."
>
  <!-- Hero -->
  <section class="bg-[#0F172A] py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-[#F97316] text-sm font-semibold font-mono uppercase tracking-widest">Knowledge Base</span>
      <h1 class="mt-4 text-4xl md:text-5xl font-bold text-white tracking-tight">Authority Resources</h1>
      <p class="mt-4 text-lg text-slate-300 max-w-2xl">Tactical guides, frameworks, and playbooks for building your expert visibility in 2026.</p>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="py-20 bg-[#F8FAFC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        {articles.map((article, i) => (
          <a
            href={`/resources/${article.slug}`}
            class={`bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg hover:border-[#F97316]/30 transition-all duration-200 group ${i === 0 ? 'md:col-span-2' : ''}`}
          >
            {i === 0 ? (
              <div class="p-10">
                <div class="flex flex-wrap items-center gap-3 mb-4">
                  <span class="bg-[#F97316] text-white text-xs font-bold px-3 py-1 rounded-full">Featured</span>
                  {article.data.tags?.slice(0, 3).map(tag => (
                    <span class="bg-slate-100 text-slate-600 text-xs px-3 py-1 rounded-full capitalize">{tag}</span>
                  ))}
                </div>
                <h2 class="text-2xl md:text-3xl font-bold text-[#0F172A] mb-4 group-hover:text-[#F97316] transition-colors leading-tight">{article.data.title}</h2>
                <p class="text-slate-600 leading-relaxed mb-6 max-w-3xl">{article.data.summary}</p>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-[#0F172A] flex items-center justify-center text-white text-xs font-bold">GK</div>
                    <div>
                      <p class="text-sm font-semibold text-slate-700">{article.data.author}</p>
                      <p class="text-xs text-slate-400">{new Date(article.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                    </div>
                  </div>
                  <span class="text-[#F97316] font-semibold text-sm group-hover:underline">Read article →</span>
                </div>
              </div>
            ) : (
              <div class="p-8">
                <div class="flex flex-wrap gap-2 mb-3">
                  {article.data.tags?.slice(0, 2).map(tag => (
                    <span class="bg-slate-100 text-slate-600 text-xs px-3 py-1 rounded-full capitalize">{tag}</span>
                  ))}
                </div>
                <h2 class="text-xl font-bold text-[#0F172A] mb-3 group-hover:text-[#F97316] transition-colors leading-snug">{article.data.title}</h2>
                <p class="text-slate-600 text-sm leading-relaxed mb-5 line-clamp-3">{article.data.summary}</p>
                <div class="flex items-center justify-between">
                  <p class="text-xs text-slate-400">{new Date(article.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                  <span class="text-[#F97316] font-semibold text-sm group-hover:underline">Read →</span>
                </div>
              </div>
            )}
          </a>
        ))}
      </div>

      <!-- Industry Guides -->
      <div class="mb-4">
        <h2 class="text-2xl font-bold text-[#0F172A] mb-2">Industry Visibility Guides</h2>
        <p class="text-slate-600 mb-6">Niche-specific authority playbooks for your industry.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {industries.map(ind => (
          <a
            href={`/guides/how-to-get-known-in-${ind.slug}`}
            class="bg-white rounded-xl p-5 border border-slate-200 hover:border-[#F97316] hover:shadow-sm transition-all group text-center"
          >
            <div class="w-10 h-10 rounded-xl bg-[#F97316]/10 flex items-center justify-center text-[#F97316] mx-auto mb-3">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
            </div>
            <p class="font-semibold text-[#0F172A] text-sm group-hover:text-[#F97316] transition-colors">How to Get Known in {ind.name}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 bg-[#0F172A]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Get the Authority Weekly</h2>
      <p class="text-slate-300 mb-8">Every Sunday — one actionable insight on authority building, personal branding, and expert visibility. No fluff.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" onsubmit="return false">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 px-5 py-3.5 rounded-full bg-white/10 border border-white/20 text-white placeholder-slate-400 focus:outline-none focus:border-[#F97316] transition-colors"
        />
        <button type="submit" class="bg-[#F97316] text-white font-bold px-7 py-3.5 rounded-full hover:bg-orange-600 transition-colors whitespace-nowrap">
          Subscribe Free
        </button>
      </form>
      <p class="text-slate-500 text-xs mt-4">Join 12,000+ experts. Unsubscribe anytime.</p>
    </div>
  </section>
</BaseLayout>
