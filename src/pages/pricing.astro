---
import BaseLayout from '../layouts/BaseLayout.astro';

const plans = [
  {
    name: 'Foundations',
    price: '$49',
    period: '/month',
    desc: 'For experts just starting their visibility journey.',
    cta: 'Start Free Trial',
    ctaHref: '/audit',
    highlight: false,
    features: [
      'Visibility Scorecard & audit',
      'LinkedIn profile optimization guide',
      'Category of One positioning worksheet',
      'Monthly content calendar template',
      'Authority SEO keyword report',
      'Email support',
    ],
  },
  {
    name: 'Authority',
    price: '$149',
    period: '/month',
    desc: 'For rising experts ready to build consistent visibility.',
    cta: 'Start Free Trial',
    ctaHref: '/audit',
    highlight: true,
    badge: 'Most Popular',
    features: [
      'Everything in Foundations',
      'AI-powered content generation',
      'Podcast guesting pitch templates',
      'Weekly Authority Weekly newsletter',
      'Content repurposing system',
      'Bi-weekly group strategy calls',
      'Personal brand website audit',
      'Priority email + chat support',
    ],
  },
  {
    name: 'Icon',
    price: '$499',
    period: '/month',
    desc: 'For established experts scaling toward tier-1 PR.',
    cta: 'Book a Call',
    ctaHref: '/audit',
    highlight: false,
    features: [
      'Everything in Authority',
      'Dedicated visibility strategist (1:1 monthly)',
      'Tier-1 PR matching & media placement',
      'Speaker bureau introduction',
      'Press kit creation & distribution',
      'Podcast booking concierge (5/month)',
      'LinkedIn ghostwriting (8 posts/month)',
      'Journalist & analyst database access',
    ],
  },
];
---

<BaseLayout
  title="Pricing — GetKnown"
  description="Transparent, results-driven pricing for expert visibility. Start free with the Visibility Scorecard, then choose the plan that matches your authority goals."
>
  <!-- Hero -->
  <section class="bg-neutral-950 pt-32 pb-20">
    <div class="container mx-auto px-6 lg:px-12 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 mb-6">
        <iconify-icon icon="solar:tag-price-linear" width="16" height="16" class="text-blue-400"></iconify-icon>
        <span class="text-[11px] font-medium uppercase tracking-[0.18em] text-blue-300 font-geist">Simple Pricing</span>
      </div>
      <h1 class="text-4xl lg:text-5xl font-semibold text-white tracking-tight font-geist mb-4">Invest in your authority.</h1>
      <p class="text-lg text-neutral-400 font-geist max-w-xl mx-auto">Start with the free Visibility Audit. Upgrade when you're ready to scale.</p>
    </div>
  </section>

  <!-- Plans -->
  <section class="py-20 bg-neutral-100/50">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {plans.map(plan => (
          <div class={`rounded-2xl overflow-hidden flex flex-col ${plan.highlight ? 'shadow-[0_0_40px_-8px_rgba(37,99,235,0.35)] ring-2 ring-blue-600' : 'border border-neutral-200 shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]'}`}>
            {plan.highlight ? (
              <div class="bg-blue-600 px-8 py-6">
                <div class="flex justify-between items-start mb-2">
                  <h2 class="text-xl font-semibold text-white font-geist">{plan.name}</h2>
                  {plan.badge && <span class="bg-white text-blue-600 text-xs font-semibold px-3 py-1 rounded-full font-geist">{plan.badge}</span>}
                </div>
                <div class="flex items-end gap-1">
                  <span class="text-4xl font-semibold text-white font-geist">{plan.price}</span>
                  <span class="text-blue-200 pb-1 font-geist text-sm">{plan.period}</span>
                </div>
                <p class="text-blue-100 text-sm mt-2 font-geist">{plan.desc}</p>
              </div>
            ) : (
              <div class="bg-neutral-950 px-8 py-6">
                <h2 class="text-xl font-semibold text-white mb-2 font-geist">{plan.name}</h2>
                <div class="flex items-end gap-1">
                  <span class="text-4xl font-semibold text-white font-geist">{plan.price}</span>
                  <span class="text-neutral-400 pb-1 font-geist text-sm">{plan.period}</span>
                </div>
                <p class="text-neutral-300 text-sm mt-2 font-geist">{plan.desc}</p>
              </div>
            )}

            <div class="p-8 flex-1 flex flex-col bg-white">
              <ul class="space-y-3 mb-8 flex-1">
                {plan.features.map(f => (
                  <li class="flex items-start gap-3 text-sm text-neutral-700 font-geist">
                    <iconify-icon icon="solar:check-circle-linear" width="16" height="16" class="text-blue-600 mt-0.5 flex-shrink-0"></iconify-icon>
                    {f}
                  </li>
                ))}
              </ul>

              <a href={plan.ctaHref}
                class={`w-full text-center font-medium py-3.5 rounded-lg transition-colors font-geist text-sm block ${plan.highlight ? 'bg-blue-600 text-white hover:bg-blue-700' : 'border-2 border-neutral-200 text-neutral-800 hover:border-blue-600 hover:text-blue-600'}`}
              >
                {plan.cta}
              </a>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-neutral-500 text-sm mt-8 font-geist">All plans include a 14-day free trial. No credit card required to start.</p>
    </div>
  </section>

  <!-- Add-ons -->
  <section class="py-16 bg-white border-t border-neutral-100">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-semibold text-neutral-900 mb-3 font-geist tracking-tight">Power-Ups & Add-Ons</h2>
        <p class="text-neutral-500 font-geist">Extend your plan with targeted visibility services.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          { name: 'Founder + Team Package', price: 'from $799/mo', desc: 'Extend Authority or Icon plans to 3 executives simultaneously' },
          { name: '1:1 Strategy Intensive', price: '$1,200 one-time', desc: 'Full-day working session to build your complete visibility roadmap' },
          { name: 'LinkedIn Ghostwriting', price: '$299/mo', desc: 'Monthly package of 12 posts researched, written, and scheduled for you' },
        ].map(addon => (
          <div class="bg-neutral-50 rounded-2xl p-8 border border-neutral-100 shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]">
            <p class="text-blue-600 font-semibold text-lg mb-1 font-geist">{addon.price}</p>
            <h3 class="font-semibold text-neutral-900 text-lg mb-3 font-geist">{addon.name}</h3>
            <p class="text-neutral-500 text-sm font-geist">{addon.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guarantee -->
  <section class="py-16 bg-neutral-950 border-t border-neutral-900">
    <div class="container mx-auto px-6 lg:px-12 text-center max-w-3xl">
      <div class="w-16 h-16 rounded-full bg-blue-600/20 flex items-center justify-center text-blue-400 mx-auto mb-6 border border-blue-500/30">
        <iconify-icon icon="solar:shield-check-linear" width="32" height="32" stroke-width="1.5"></iconify-icon>
      </div>
      <h2 class="text-3xl font-semibold text-white mb-4 font-geist tracking-tight">30-Day Results Guarantee</h2>
      <p class="text-lg text-neutral-400 font-geist">If you implement our Visibility Foundations system and don't see a measurable increase in profile views and inbound inquiries within 30 days, we'll refund your first month — no questions asked.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white border-t border-neutral-100">
    <div class="container mx-auto px-6 lg:px-12 max-w-3xl">
      <h2 class="text-2xl font-semibold text-neutral-900 mb-8 text-center font-geist tracking-tight">Pricing FAQs</h2>
      <div class="space-y-4">
        {[
          { q: 'Can I switch plans?', a: 'Yes. You can upgrade or downgrade at any time. Changes take effect on your next billing cycle.' },
          { q: 'Is there a long-term contract?', a: 'No. All plans are month-to-month. Annual billing is available at a 20% discount.' },
          { q: "What's included in the free trial?", a: 'Full access to your chosen plan for 14 days. No credit card required. At the end, you can subscribe or walk away.' },
          { q: 'Do you offer discounts for early-stage founders?', a: 'Yes. We offer a 50% founding member discount for early-stage founders. Contact us directly to apply.' },
        ].map(faq => (
          <details class="group bg-neutral-50 rounded-2xl border border-neutral-100 overflow-hidden shadow-[0_2px_10px_-4px_rgba(0,0,0,0.05)]">
            <summary class="flex justify-between items-center px-6 py-5 cursor-pointer list-none text-neutral-900 font-medium hover:bg-neutral-100 transition-colors font-geist text-sm">
              {faq.q}
              <iconify-icon icon="solar:alt-arrow-down-linear" width="18" height="18" class="text-neutral-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4"></iconify-icon>
            </summary>
            <div class="px-6 pb-5 text-neutral-500 leading-relaxed font-geist text-sm">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
