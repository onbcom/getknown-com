---
const currentPath = Astro.url.pathname;
---

<!-- Navigation (Fixed Pill) -->
<nav class="fixed -translate-x-1/2 flex transition-all duration-300 bg-white/90 w-[92%] max-w-3xl z-50 border-neutral-200/60 border rounded-full pt-3 pr-3 pb-3 pl-3 top-6 left-1/2 shadow-[0_8px_30px_rgb(0,0,0,0.06)] backdrop-blur-md items-center justify-between">
  <div class="flex items-center gap-2 pl-2">
    <a href="/" class="flex items-center gap-2">
      <div class="flex text-white bg-blue-600 w-8 h-8 rounded-full items-center justify-center shadow-md">
        <iconify-icon icon="solar:star-fall-linear" width="18" height="18" stroke-width="1.5"></iconify-icon>
      </div>
      <span class="text-lg font-semibold tracking-tight font-geist text-neutral-900">GetKnown.com</span>
    </a>
  </div>
  <div class="hidden md:flex items-center gap-8 text-sm font-medium text-neutral-500">
    <a href="/platform" class={`hover:text-blue-600 transition-colors font-geist ${currentPath.startsWith('/platform') ? 'text-blue-600' : ''}`}>Platform</a>
    <a href="/resources" class={`hover:text-blue-600 transition-colors font-geist ${currentPath.startsWith('/resources') ? 'text-blue-600' : ''}`}>Guides</a>
    <a href="/resources" class={`hover:text-blue-600 transition-colors font-geist ${currentPath.startsWith('/resources') ? 'text-blue-600' : ''}`}>Resources</a>
    <a href="/pricing" class={`hover:text-blue-600 transition-colors font-geist ${currentPath.startsWith('/pricing') ? 'text-blue-600' : ''}`}>Pricing</a>
  </div>
  <div class="flex items-center gap-2">
    <a href="/audit" class="hidden md:flex items-center justify-center px-5 py-2 rounded-full bg-blue-600 text-white font-medium text-sm hover:bg-blue-700 transition-colors shadow-sm font-geist">
      Audit Brand
    </a>
    <!-- Mobile menu button -->
    <button id="mobile-menu-toggle" class="md:hidden p-2 rounded-full text-neutral-600 hover:bg-neutral-100 transition-colors" aria-label="Open menu">
      <iconify-icon icon="solar:hamburger-menu-linear" width="20" height="20"></iconify-icon>
    </button>
  </div>
</nav>

<!-- Mobile Menu Dropdown -->
<div id="mobile-menu" class="hidden fixed top-20 left-1/2 -translate-x-1/2 w-[92%] max-w-3xl z-40 bg-white/95 backdrop-blur-md border border-neutral-200/60 rounded-2xl shadow-lg p-4">
  <div class="flex flex-col gap-2">
    <a href="/platform" class="font-geist text-sm font-medium text-neutral-700 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-blue-50 transition-colors">Platform</a>
    <a href="/resources" class="font-geist text-sm font-medium text-neutral-700 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-blue-50 transition-colors">Guides</a>
    <a href="/resources" class="font-geist text-sm font-medium text-neutral-700 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-blue-50 transition-colors">Resources</a>
    <a href="/pricing" class="font-geist text-sm font-medium text-neutral-700 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-blue-50 transition-colors">Pricing</a>
    <a href="/audit" class="mt-2 flex items-center justify-center px-5 py-2.5 rounded-full bg-blue-600 text-white font-medium text-sm hover:bg-blue-700 transition-colors font-geist">
      Audit Brand
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.add('hidden');
    }
  });
</script>
